#include <iostream>
using namespace std;

class SmartDelivery  {
	protected:
	int id;
	double cost;
	string name;
	public:
	void display(int id, double cost, string name)
	{
		cout << " Common Delivery Information " << endl;
		cout << " ID: " << id << endl;
		cout << " Cost: " << cost << endl;
		cout << " Customer Name: " << name << endl;
	}
	
};

class ExpressDelivery : public SmartDelivery {

	public:
	using SmartDelivery:: display;
	void display(int id, double cost, string name, string prioritylevel )
	{
		cout << " Express Delivery Information " << endl;
		cout << " ID: " << id << endl;
		cout << " Cost " << cost << endl;
		cout << " Customer Name: " << name << endl;
		cout << " Priority Level " << prioritylevel << endl;
	}
};

int main()
{
	ExpressDelivery e1;
	e1.display(101,700," Zubair ");
	
	e1.display(102,900," Musawir ", " High");
}
