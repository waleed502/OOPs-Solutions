#include<iostream>
using namespace std;
class Library
{
	protected:
		string title;
		string author;
		int id;
	public:
		Library(string title,string author,int id)
		{
			this->title=title;
			this->author=author;
			this->id=id;
		}
	virtual void display()
	{
		
	}
};
class Book: public Library
{
	private:
	int noOfPages;
	string genre;
	public:
	Book (string title,string author, int id,int noOfPages,string genre):Library(title,author,id)
	{
		this->noOfPages=noOfPages;
		this->genre=genre;
	}
	void display ()
	{
		cout<<"Book title "<<title<<endl;
		cout<<"Author of the book is "<<author<<endl;
		cout<<"Id of the book is "<<id<<endl;
		cout<<"Number of pages in the book are "<<noOfPages<<endl;
		cout<<"Genre of the book is "<<genre<<endl;
		
	}
};
class Magzine:public Library
{
	private:
		int issueNumber;
		string publicationMonth;
	public:
	Magzine(string title,string author, int id,int issueNumber,string publicationMonth):Library(title,author,id)
	{
		this->issueNumber=issueNumber;
		this->publicationMonth=publicationMonth;
	}
	void display()
	{
		cout<<"Magzine title "<<title<<endl;
		cout<<"Author of the magzine is "<<author<<endl;
		cout<<"Id of the magzine is "<<id<<endl;
		cout<<"Issue number  of magzine is "<<issueNumber<<endl;
		cout<<"Publication month of magzine is "<<publicationMonth<<endl;
	}
};
class audioBook:public Library
		{
	private:
		int duration;
		string narratorName;
	public:	
	audioBook (string title,string author, int id,int duration,string narratorName):Library(title,author,id)
	{
	this->duration=duration;
	this->narratorName=narratorName;
	}
	void display()
	{
		cout<<"Audio Book title "<<title<<endl;
		cout<<"Audio book of the magzine is "<<author<<endl;
		cout<<"Id of the audio book is "<<id<<endl;
		cout<<"Duration of the audio book is "<<duration<<endl;
		cout<<"Narrator of the audio book is "<<narratorName<<endl;
	}
};
